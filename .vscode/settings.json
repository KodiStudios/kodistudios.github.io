{
  // Enforce Unix-style (LF) line endings in VS Code.
  // Otherwise the default line ending is CRLF on Windows,
  // which can cause issues in cross-platform development.
  // Note: A more generic cross-editor approach is .editorconfig,
  // but VS Code doesn't support it without a third-party extension.
  "files.eol": "\n",

  // Formatting
  "[typescript]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode",
    "editor.formatOnSave": true
  },

  // .tsx files
  "[typescriptreact]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode",
    "editor.formatOnSave": true
  },

  "[json]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode",
    "editor.formatOnSave": true
  },

  // Spelling
  "cSpell.allowCompoundWords": true,
  "cSpell.words": [
    "Alki",
    "Aristov",
    "Claudinary",
    "Cloudify",
    "clsx",
    "docu",
    "Infima",
    "Kodi",
    "kodistudios",
    "mywebsite",
    "nikoari",
    "Sakura",
    "Tldr",
    "Tonivo",
    "xcopy",
    "yoururl"
  ],

  // Terminal - PowerShell launching CMD for Copilot compatibility
  "terminal.integrated.profiles.windows": {
    "Kodi": {
      "source": "PowerShell",
      "args": ["-NoExit", "-Command", "cmd"],
      "overrideName": true
    }
  },
  "terminal.integrated.defaultProfile.windows": "Kodi"
}
