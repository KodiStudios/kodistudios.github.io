{
  "name": "kodi-website",
  "version": "0.26.1",
  "private": true,
  "license": "UNLICENSED",
  "scripts": {
    "docusaurus": "docusaurus",
    "start": "docusaurus start",
    "build": "docusaurus build",
    "swizzle": "docusaurus swizzle",
    "deploy": "docusaurus deploy",
    "clear:docu": "docusaurus clear",
    "serve": "docusaurus serve",
    "write-translations": "docusaurus write-translations",
    "write-heading-ids": "docusaurus write-heading-ids",
    "lint": "yarn typecheck && yarn format && yarn eslint",
    "eslint": "eslint --fix .",
    "format": "prettier --write .",
    "//update:yarn": "Updates packageManager field",
    "update:yarn": "corepack use yarn@latest",
    "update": "node scripts/update.mts",
    "typecheck": "tsc",
    "clean": "node scripts/clean.mts"
  },
  "dependencies": {
    "@docusaurus/core": "^3.9.2",
    "@docusaurus/preset-classic": "^3.9.2",
    "@mdx-js/react": "^3.1.1",
    "clsx": "^2.1.1",
    "prism-react-renderer": "^2.4.1",
    "react": "^18",
    "react-dom": "^18"
  },
  "devDependencies": {
    "@docusaurus/module-type-aliases": "^3.9.2",
    "@docusaurus/tsconfig": "^3.9.2",
    "@docusaurus/types": "^3.9.2",
    "@eslint/js": "^10.0.1",
    "@types/node": "^24",
    "@types/react": "^18",
    "@types/react-dom": "^18",
    "eslint": "^10.0.2",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-react-hooks": "^7.0.1",
    "globals": "^17.4.0",
    "prettier": "^3.8.1",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.56.1"
  },
  "//resolutions": "Docusaurus Sets Dependency to @types/react:*",
  "resolutions": {
    "@types/react": "^18",
    "@types/react-dom": "^18"
  },
  "browserslist": {
    "production": [
      ">0.5%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  },
  "engines": {
    "node": ">=24.0.0"
  },
  "packageManager": "yarn@4.12.0"
}
