{
  "name": "kodi-website",
  "version": "0.26.1",
  "private": true,
  "license": "UNLICENSED",
  "scripts": {
    "//-- Development --//": "",
    "//start": "Dev server with hot reload",
    "start": "docusaurus start",
    "build": "docusaurus build",
    "//serve": "Serves the build/ output locally (run yarn build first)",
    "serve": "docusaurus serve",
    "//-- Code quality --//": "",
    "lint": "yarn typecheck && yarn format && yarn eslint",
    "typecheck": "tsc",
    "format": "prettier --write .",
    "eslint": "eslint --fix .",
    "//-- Maintenance --//": "",
    "clean": "node scripts/clean.mts",
    "clear:docu": "docusaurus clear",
    "//update": "Updates dependencies, devDependencies, and Yarn itself",
    "update": "node scripts/update.mts",
    "//-- Docusaurus --//": "",
    "swizzle": "docusaurus swizzle"
  },
  "dependencies": {
    "@docusaurus/core": "^3.9.2",
    "@docusaurus/preset-classic": "^3.9.2",
    "@mdx-js/react": "^3.1.1",
    "clsx": "^2.1.1",
    "prism-react-renderer": "^2.4.1",
    "react": "^18",
    "react-dom": "^18"
  },
  "devDependencies": {
    "@docusaurus/module-type-aliases": "^3.9.2",
    "@docusaurus/tsconfig": "^3.9.2",
    "@docusaurus/types": "^3.9.2",
    "@eslint/js": "^10.0.1",
    "@types/node": "^24",
    "@types/react": "^18",
    "@types/react-dom": "^18",
    "eslint": "^10.0.2",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-react-hooks": "^7.0.1",
    "globals": "^17.4.0",
    "prettier": "^3.8.1",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.56.1"
  },
  "//resolutions": "Docusaurus Sets Dependency to @types/react:*",
  "resolutions": {
    "@types/react": "^18",
    "@types/react-dom": "^18"
  },
  "browserslist": {
    "production": [
      ">0.5%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  },
  "engines": {
    "node": ">=24.0.0"
  },
  "packageManager": "yarn@4.12.0"
}
